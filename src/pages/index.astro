---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LinkCard from '@/components/LinkCard.astro';
import NavIcon from '@/components/NavIcon.astro';
import PostCard from '@/components/PostCard.astro';
import { SITE } from '@/lib/constants';
import { fetchOgImage } from '@/lib/og-image';
import { getCollection } from 'astro:content';
import { sortPosts } from '@/lib/utils';

const blog = await getCollection('blog');
const links = await getCollection('links');

const recentBlog = sortPosts(blog).slice(0, 5);
const recentInspiration = sortPosts(links).slice(0, 6);

const inspirationItems = await Promise.all(
  recentInspiration.map(async (post) => ({
    post,
    ogImage: post.data.ogImage ?? (await fetchOgImage(post.data.externalUrl)),
  }))
);
---

<BaseLayout title={SITE.title} description={SITE.description} breadcrumb="Home">
  <section class="text-center mb-12">
    <img
      src="/profile.png"
      alt="Malhar Ujawane"
      class="w-24 h-24 rounded-full object-cover mx-auto mb-5 ring-2 ring-apple-gray-100"
    />
    <h1 class="text-[22px] font-bold text-apple-gray-900 tracking-[-0.02em] mb-3">
      Malhar Ujawane
    </h1>
    <div class="text-[15px] text-apple-gray-500 leading-relaxed max-w-[560px] mx-auto mb-5 text-balance space-y-3">
      <p>
        I lead AI Solutions and Delivery in MobiiLabs at <a href="https://mobiiworld.com" target="_blank" rel="noopener noreferrer" class="text-apple-orange hover:text-apple-orange/70 transition-colors font-medium">Mobii</a>, building enterprise AI for Dubai.
        Before that: 10+ years in the US, Silicon Valley at <a href="https://walmart.com" target="_blank" rel="noopener noreferrer" class="text-apple-orange hover:text-apple-orange/70 transition-colors font-medium">Walmart</a>, plus <a href="https://potterybarn.com" target="_blank" rel="noopener noreferrer" class="text-apple-orange hover:text-apple-orange/70 transition-colors font-medium">Pottery Barn</a> and <a href="https://westelm.com" target="_blank" rel="noopener noreferrer" class="text-apple-orange hover:text-apple-orange/70 transition-colors font-medium">West Elm</a>, shipping to millions.
      </p>
      <p>
        I write about <a href="/tags/ai" class="text-apple-orange hover:text-apple-orange/70 transition-colors font-medium">AI</a>, <a href="/tags/software engineering" class="text-apple-orange hover:text-apple-orange/70 transition-colors font-medium">software engineering</a>, <a href="/tags/opensource" class="text-apple-orange hover:text-apple-orange/70 transition-colors font-medium">opensource</a>, and <a href="/tags/books" class="text-apple-orange hover:text-apple-orange/70 transition-colors font-medium">books</a>; open-source hundreds of projects on <a href={SITE.social.github} target="_blank" rel="noopener noreferrer" class="text-apple-orange hover:text-apple-orange/70 transition-colors font-medium">GitHub</a>; and I&rsquo;m building <a href="https://getmaverick.sh" target="_blank" rel="noopener noreferrer" class="text-apple-orange hover:text-apple-orange/70 transition-colors font-medium">Maverick</a>.
      </p>
    </div>

    <div class="flex items-center justify-center gap-1">
      <a href={SITE.social.twitter} target="_blank" rel="noopener" class="p-2 rounded-lg text-apple-gray-400 hover:text-apple-orange hover:bg-apple-orange/5 transition-all" aria-label="Twitter / X">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16z"/><path d="M4 20l6.768 -6.768m2.46 -2.46L20 4"/></svg>
      </a>
      <a href={SITE.social.github} target="_blank" rel="noopener" class="p-2 rounded-lg text-apple-gray-400 hover:text-apple-orange hover:bg-apple-orange/5 transition-all" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
      </a>
      <a href={SITE.social.linkedin} target="_blank" rel="noopener" class="p-2 rounded-lg text-apple-gray-400 hover:text-apple-orange hover:bg-apple-orange/5 transition-all" aria-label="LinkedIn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
      </a>
      <a href={SITE.social.instagram} target="_blank" rel="noopener" class="p-2 rounded-lg text-apple-gray-400 hover:text-apple-orange hover:bg-apple-orange/5 transition-all" aria-label="Instagram">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
      </a>
    </div>
  </section>

  {recentBlog.length > 0 && (
    <section class="mb-12">
      <div class="flex items-center gap-2 mb-4">
        <NavIcon name="blog" class="text-apple-orange" />
        <h2 class="text-[18px] font-bold text-apple-gray-900 tracking-[-0.02em]">Blog</h2>
      </div>
      <div class="divide-y divide-apple-gray-100">
        {recentBlog.map(post => (
          <PostCard post={post} variant="card" />
        ))}
      </div>
      <div class="mt-6">
        <a href="/blog" class="text-[14px] font-medium text-apple-orange hover:text-apple-orange/70 transition-colors">
          View all articles →
        </a>
      </div>
    </section>
  )}

  {inspirationItems.length > 0 && (
    <section>
      <div class="flex items-center gap-2 mb-6">
        <NavIcon name="inspiration" class="text-apple-orange" />
        <h2 class="text-[18px] font-bold text-apple-gray-900 tracking-[-0.02em]">Inspiration</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-10">
        {inspirationItems.map(({ post, ogImage }) => (
          <LinkCard post={post} ogImage={ogImage} />
        ))}
      </div>
      <div class="mt-8">
        <a href="/inspiration" class="text-[14px] font-medium text-apple-orange hover:text-apple-orange/70 transition-colors">
          View all inspiration →
        </a>
      </div>
    </section>
  )}
</BaseLayout>
