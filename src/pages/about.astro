---
import ArrowLink from '@/components/ArrowLink.astro';
import Portrait from '@/components/Portrait.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { aboutContent, site } from '@/data/site';
import { socialLinks } from '@/data/social';
---

<BaseLayout
  title={`About · ${site.name}`}
  description={`About ${site.name} — software engineer writing on AI systems and engineering craft.`}
  activeNav="/about"
>
  <section class="about-page reveal">
    <div class="about-page__grid">
      <div class="about-page__intro">
        <span class="eyebrow">About</span>
        <h1 class="section-title">{aboutContent.headline}</h1>
      </div>
      <Portrait class="about-page__portrait reveal-scale" />
    </div>
  </section>

  <div class="prose about-copy reveal">
    {aboutContent.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    <div class="about-contact">
      <a href={`mailto:${site.email}`}>{site.email}</a>
      {
        socialLinks.map((link, index) => (
          <>
            {index === 0 ? null : <span class="about-contact__sep" aria-hidden="true">·</span>}
            <a href={link.href} target="_blank" rel="noopener noreferrer me">
              {link.label.replace(' (Twitter)', '')}
            </a>
          </>
        ))
      }
    </div>
    <p class="about-cta">
      <ArrowLink href="/setup" label="See my setup" />
    </p>
  </div>
</BaseLayout>
