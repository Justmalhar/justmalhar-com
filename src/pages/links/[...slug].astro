---
import PostLayout from '@/layouts/PostLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('links');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<PostLayout
  title={post.data.title || 'Link'}
  description={post.data.description}
  pubDate={post.data.pubDate}
  tags={post.data.tags}
  type="Link"
>
  <div class="p-4 bg-apple-gray-50 rounded-xl mb-6">
    <a href={post.data.externalUrl} target="_blank" rel="noopener" class="text-apple-blue underline underline-offset-2 decoration-apple-blue/30 hover:decoration-apple-blue/80 transition-all font-medium">
      {post.data.externalUrl} ↗
    </a>
    {post.data.via && (
      <span class="block mt-2 text-[15px] text-apple-gray-400">via {post.data.via}</span>
    )}
  </div>
  <Content />
</PostLayout>
