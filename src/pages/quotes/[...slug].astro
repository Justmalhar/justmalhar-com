---
import PostLayout from '@/layouts/PostLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('quotes');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<PostLayout
  title={post.data.author ? `Quoting ${post.data.author}` : 'Quote'}
  pubDate={post.data.pubDate}
  tags={post.data.tags}
  type="Quote"
>
  <blockquote class="border-l-[3px] border-apple-gray-900 my-8 pl-5 text-subhead text-apple-gray-600 leading-relaxed">
    <Content />
  </blockquote>
  <p class="text-[15px] text-apple-gray-400 italic">— {post.data.author}</p>
</PostLayout>
