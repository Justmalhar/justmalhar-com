---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/constants';
import { getCollection } from 'astro:content';

const setupItems = await getCollection('setup');

const categories = [
  { id: 'hardware', label: 'Hardware', icon: '💻', description: 'The devices I use daily' },
  { id: 'os', label: 'Operating System', icon: '🍎', description: 'My primary OS and config' },
  { id: 'editor', label: 'Editor', icon: '✏️', description: 'Where I write code' },
  { id: 'terminal', label: 'Terminal', icon: '⬛', description: 'Shell and CLI tools' },
  { id: 'ai', label: 'AI Tools', icon: '🤖', description: 'AI assistants and models' },
  { id: 'browser', label: 'Browser', icon: '🌐', description: 'Web browser and extensions' },
  { id: 'productivity', label: 'Productivity', icon: '⚡', description: 'Apps that keep me organized' },
  { id: 'deploy', label: 'Deploy', icon: '🚀', description: 'Deployment and infrastructure' },
];

function getItemsForCategory(categoryId: string) {
  return setupItems
    .filter(item => item.data.category === categoryId)
    .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
}
---

<BaseLayout title={`Setup — ${SITE.title}`} description="The hardware, software, and tools I use every day.">
  <div class="max-w-content">
    <header class="mb-16">
      <h1 class="text-display text-apple-gray-900 mb-4">Setup</h1>
      <p class="text-subhead text-apple-gray-500">
        The hardware, software, and tools I use every day.
      </p>
      <p class="text-[15px] text-apple-gray-400 mt-4">
        Inspired by <a href="https://sive.rs/setup" target="_blank" rel="noopener" class="text-apple-blue underline underline-offset-2 decoration-apple-blue/30 hover:decoration-apple-blue/80 transition-all">sive.rs/setup</a> and <a href="https://willpatrick.co.uk/setup" target="_blank" rel="noopener" class="text-apple-blue underline underline-offset-2 decoration-apple-blue/30 hover:decoration-apple-blue/80 transition-all">willpatrick.co.uk/setup</a>
      </p>
    </header>

    <div class="space-y-14">
      {categories.map(category => {
        const items = getItemsForCategory(category.id);
        if (items.length === 0) return null;
        return (
          <section>
            <div class="flex items-center gap-3 mb-6 pb-4 border-b border-apple-gray-100">
              <span class="text-xl">{category.icon}</span>
              <div>
                <h2 class="text-[20px] font-semibold text-apple-gray-900 tracking-tight">{category.label}</h2>
                <p class="text-[15px] text-apple-gray-400">{category.description}</p>
              </div>
            </div>
            <div class="space-y-5">
              {items.map(item => (
                <article class="flex items-start gap-4">
                  <span class="text-lg mt-0.5">{item.data.icon || '•'}</span>
                  <div class="flex-1">
                    <div class="flex items-center gap-2">
                      {item.data.url ? (
                        <a href={item.data.url} target="_blank" rel="noopener" class="text-[17px] font-semibold text-apple-gray-900 hover:text-apple-blue transition-colors">
                          {item.data.title}
                        </a>
                      ) : (
                        <span class="text-[17px] font-semibold text-apple-gray-900">{item.data.title}</span>
                      )}
                    </div>
                    <p class="text-[15px] text-apple-gray-500 mt-1 leading-relaxed">{item.data.description}</p>
                  </div>
                </article>
              ))}
            </div>
          </section>
        );
      })}
    </div>
  </div>
</BaseLayout>
