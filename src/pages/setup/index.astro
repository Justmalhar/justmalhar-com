---
import PageHero from '@/components/PageHero.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { setupCategories, setupIntro, setupUpdated } from '@/data/setup';
import { site } from '@/data/site';
---

<BaseLayout
  title={`Setup · ${site.name}`}
  description="Hardware, software, and tools Malhar Ujawane uses to build and write."
  activeNav="/setup"
>
  <PageHero eyebrow="Setup" title="What I use." lead={setupIntro} compact>
    <p class="setup-updated">Last updated {setupUpdated}</p>
  </PageHero>

  <div class="setup reveal">
    {
      setupCategories.map((category) => (
        <section
          class="setup-category"
          aria-labelledby={`setup-${category.title.replace(/\s+/g, '-').toLowerCase()}`}
        >
          <header class="setup-category__head">
            <h2 id={`setup-${category.title.replace(/\s+/g, '-').toLowerCase()}`}>{category.title}</h2>
            {category.description && <p>{category.description}</p>}
          </header>
          <dl class="setup-specs">
            {category.items.map((item) => (
              <>
                <dt>
                  {item.href ? (
                    <a href={item.href} target="_blank" rel="noopener noreferrer">
                      {item.name}
                    </a>
                  ) : (
                    item.name
                  )}
                </dt>
                <dd>{item.detail ?? '—'}</dd>
              </>
            ))}
          </dl>
        </section>
      ))
    }
  </div>

  <p class="setup-footnote reveal">
    Questions or recommendations? <a href={`mailto:${site.email}`}>Say hello</a>.
  </p>
</BaseLayout>
