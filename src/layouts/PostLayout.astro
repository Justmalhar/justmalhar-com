---
import Mermaid from '@/components/Mermaid.astro';
import PostFooter from '@/components/PostFooter.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { readingTime } from '@/lib/reading-time';
import { BLOG_SECTIONS, getPublishedPosts, type BlogSection } from '@/lib/sections';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  section: BlogSection;
  slug: string;
  body: string;
}

const { title, description, pubDate, updatedDate, tags = [], section, slug, body } = Astro.props;
const sectionConfig = BLOG_SECTIONS[section];
const readTime = readingTime(body);

const formatted = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const related = (await getPublishedPosts())
  .filter((post) => post.id !== slug && post.data.section === section)
  .slice(0, 2);
---

<BaseLayout
  title={`${title} · Malhar Ujawane`}
  description={description}
  postSection={section}
  ogType="article"
>
  <article class="prose reveal">
    <header class="article-header">
      <a class="eyebrow eyebrow-link" href={sectionConfig.path}>{sectionConfig.eyebrow}</a>
      <h1>{title}</h1>
      <p class="dek">{description}</p>
      <p class="post-meta">
        <time datetime={pubDate.toISOString()}>{formatted}</time>
        <span aria-hidden="true"> · </span>
        <span>{readTime}</span>
        {
          updatedDate && (
            <>
              <span aria-hidden="true"> · </span>
              <span>
                Updated{' '}
                <time datetime={updatedDate.toISOString()}>
                  {updatedDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
              </span>
            </>
          )
        }
      </p>
      {
        tags.length > 0 && (
          <div class="tag-list">
            {tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )
      }
    </header>
    <div class="article-body">
      <slot />
    </div>
    <PostFooter {section} {slug} />
  </article>
  <RelatedPosts posts={related} />
  <Mermaid />
</BaseLayout>
