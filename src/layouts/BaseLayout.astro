---
import Head from '@/components/Head.astro';
import Sidebar from '@/components/Sidebar.astro';
import RightSidebar from '@/components/RightSidebar.astro';
import MobileHeader from '@/components/MobileHeader.astro';
import MobileAside from '@/components/MobileAside.astro';
import Analytics from '@vercel/analytics/astro';
import { SITE } from '@/lib/constants';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  breadcrumb?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  image,
  type,
  breadcrumb,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <Head title={title} description={description} image={image} type={type} />
  <body class="bg-white">
    <MobileHeader />

    <div class="flex w-full min-h-screen">
        <div class="hidden lg:block shrink-0">
          <Sidebar />
        </div>

        <main class="flex-1 min-w-0 lg:border-x border-apple-gray-100 bg-white">
          <div class="px-6 sm:px-8 lg:px-12 py-8 lg:py-10">
            {breadcrumb && (
              <p class="text-[13px] text-apple-gray-400 mb-6">{breadcrumb}</p>
            )}
            <slot />
          </div>

          <div class="xl:hidden">
            <MobileAside />
          </div>
        </main>

        <div class="hidden xl:block shrink-0">
          <RightSidebar />
        </div>
    </div>
    <Analytics />
  </body>
</html>
