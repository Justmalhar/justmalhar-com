---
import ArrowLink from '@/components/ArrowLink.astro';
import type { BlogSection } from '@/lib/sections';
import { BLOG_SECTIONS } from '@/lib/sections';

interface Props {
  section: BlogSection;
  slug: string;
}

const { section, slug } = Astro.props;
const sectionConfig = BLOG_SECTIONS[section];
---

<footer class="post-footer reveal">
  <div class="post-footer__links">
    <ArrowLink href="/blog" label="All writing" />
    <ArrowLink href={sectionConfig.path} label={`More ${sectionConfig.label.toLowerCase()}`} />
  </div>
</footer>
