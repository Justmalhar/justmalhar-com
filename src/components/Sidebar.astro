---
import { getCollection } from 'astro:content';
import NavIcon from '@/components/NavIcon.astro';
import { NAV_SECTIONS, SIDEBAR_TAGS, SITE } from '@/lib/constants';

const [blog, links, quotes] = await Promise.all([
  getCollection('blog'),
  getCollection('links'),
  getCollection('quotes'),
]);

const counts: Record<string, number> = {
  blog: blog.filter(p => !p.data.draft).length,
  links: links.filter(p => !p.data.draft).length,
  quotes: quotes.filter(p => !p.data.draft).length,
};

function isActive(href: string): boolean {
  if (href === '/') return Astro.url.pathname === '/';
  return Astro.url.pathname.startsWith(href);
}

function isTagActive(slug: string): boolean {
  return Astro.url.pathname === `/tags/${slug}/` || Astro.url.pathname === `/tags/${slug}`;
}
---

<aside class="sidebar-left w-[272px] shrink-0 border-r border-apple-gray-100 bg-apple-gray-50/50 flex flex-col h-screen sticky top-0 px-6">
  <div class="pt-8 pb-6">
    <a href="/" class="flex items-center gap-2 text-[15px] font-semibold text-apple-gray-900 tracking-[-0.01em] hover:text-apple-orange transition-colors">
      <svg width="20" height="20" viewBox="0 0 52 55" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-apple-orange shrink-0">
        <path d="M23.0344 0.5H29.6344C32.1544 0.5 33.1144 1.34 32.8744 3.62L31.5544 17.42C31.4344 18.26 31.9144 18.5 32.5144 17.9L43.5544 9.98C45.8344 8.66 46.7944 8.78 47.9944 11.18L51.2344 16.7C52.5544 18.86 52.1944 20.18 49.9144 21.14L37.1944 27.02C36.7144 27.38 36.7144 27.74 37.1944 27.98L49.9144 33.74C52.1944 34.82 52.5544 36.02 51.1144 38.06L47.9944 43.7C46.7944 45.74 45.5944 46.22 43.5544 44.9L32.5144 36.62C32.0344 36.14 31.4344 36.5 31.5544 37.22L32.6344 51.38C32.8744 53.78 32.0344 54.5 29.6344 54.5H23.0344C20.6344 54.5 19.7944 53.78 19.9144 51.38L21.2344 37.22C21.3544 36.5 20.8744 36.14 20.2744 36.62L8.99436 44.9C7.07436 46.22 5.87436 45.74 4.67436 43.7L1.55436 38.06C0.23436 36.02 0.35436 34.82 2.75436 33.74L15.5944 27.98C16.0744 27.74 16.0744 27.38 15.5944 27.02L2.63436 21.14C0.59436 20.18 0.23436 18.86 1.55436 16.7L4.67436 11.18C5.87436 8.78 7.07436 8.66 8.99436 9.98L20.2744 17.9C20.8744 18.5 21.3544 18.26 21.2344 17.42L19.9144 3.62C19.6744 1.34 20.6344 0.5 23.0344 0.5Z" fill="currentColor"/>
      </svg>
      {SITE.author}
    </a>
  </div>

  <nav class="flex-1 overflow-y-auto pb-6">
    {NAV_SECTIONS.map(section => (
      <div class="mb-6">
        <p class="px-2.5 mb-2.5 text-[11px] font-semibold uppercase tracking-[0.08em] text-apple-gray-400">
          {section.label}
        </p>
        <ul class="space-y-1 list-none m-0 p-0">
          {section.items.map(item => {
            const count = 'collection' in item ? counts[item.collection] : undefined;
            const active = isActive(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'flex items-center justify-between gap-2 px-2.5 py-2.5 rounded-lg text-[14px] font-medium transition-colors',
                    active
                      ? 'bg-white text-apple-gray-900 shadow-apple-sm'
                      : 'text-apple-gray-600 hover:bg-white/80 hover:text-apple-gray-900',
                  ]}
                >
                  <span class="flex items-center gap-2.5 min-w-0">
                    <NavIcon
                      name={item.icon}
                      class={active ? 'text-apple-orange' : 'text-apple-gray-400'}
                    />
                    <span>{item.label}</span>
                  </span>
                  {count !== undefined && count > 0 && (
                    <span class="text-[12px] text-apple-gray-400 tabular-nums shrink-0">{count}</span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}

    <div class="mb-6">
      <p class="px-0.5 mb-2.5 text-[11px] font-semibold uppercase tracking-[0.08em] text-apple-gray-400">
        Topics
      </p>
      <div class="flex flex-wrap gap-1.5">
        {SIDEBAR_TAGS.map(({ label, slug }) => {
          const active = isTagActive(slug);
          return (
            <a
              href={`/tags/${slug}`}
              class:list={[
                'inline-flex items-center px-2.5 py-1 rounded-full text-[12px] font-medium transition-colors',
                active
                  ? 'bg-apple-gray-900 text-white'
                  : 'bg-white text-apple-gray-600 border border-apple-gray-100 hover:bg-apple-gray-100 hover:text-apple-gray-900',
              ]}
            >
              #{label}
            </a>
          );
        })}
        <a
          href="/tags"
          class="inline-flex items-center px-2.5 py-1 rounded-full text-[12px] font-medium text-apple-gray-500 bg-white border border-apple-gray-100 hover:bg-apple-gray-100 hover:text-apple-gray-900 transition-colors"
        >
          All tags
        </a>
      </div>
    </div>
  </nav>

  <div class="pb-8">
    <a
      href="/rss.xml"
      class="flex items-center justify-center gap-2 w-full px-4 py-3 bg-apple-orange text-white rounded-xl text-[14px] font-medium hover:brightness-110 transition-all active:scale-[0.98]"
    >
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
      Subscribe via RSS
    </a>
  </div>
</aside>
