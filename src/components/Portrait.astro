---
import fs from 'node:fs';
import path from 'node:path';
import { portrait } from '@/data/home';

interface Props {
  class?: string;
  showCaption?: boolean;
  priority?: boolean;
}

const { class: className, showCaption = false, priority = false } = Astro.props;

const portraitFile = path.join(process.cwd(), 'public/images', portrait.file);
const src = fs.existsSync(portraitFile) ? `/images/${portrait.file}` : portrait.placeholder;
const isPlaceholder = src === portrait.placeholder;
---

<figure class:list={['portrait', className, isPlaceholder && 'portrait--placeholder']}>
  <div class="portrait__frame">
    <img
      src={src}
      alt={portrait.alt}
      width="400"
      height="480"
      loading={priority ? 'eager' : 'lazy'}
      decoding="async"
      fetchpriority={priority ? 'high' : 'auto'}
      class="portrait__img"
    />
  </div>
  {showCaption && isPlaceholder && <figcaption class="portrait__caption">{portrait.caption}</figcaption>}
</figure>
