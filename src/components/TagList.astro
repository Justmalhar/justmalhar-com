---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="flex flex-wrap gap-1.5">
  {tags.map(tag => (
    <a 
      href={`/tags/${tag}`} 
      class="text-[13px] text-apple-gray-500 bg-apple-gray-50 px-3 py-1 rounded-lg hover:text-apple-gray-900 hover:bg-apple-gray-100 transition-colors"
    >
      #{tag}
    </a>
  ))}
</div>
