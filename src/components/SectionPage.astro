---
import PageHero from '@/components/PageHero.astro';
import PostList from '@/components/PostList.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import type { BlogSection } from '@/lib/sections';
import { BLOG_SECTIONS } from '@/lib/sections';
import { site } from '@/data/site';

interface Props {
  section: BlogSection;
  posts: CollectionEntry<'blog'>[];
}

const { section, posts } = Astro.props;
const config = BLOG_SECTIONS[section];
---

<BaseLayout
  title={`${config.label} · ${site.name}`}
  description={config.description}
  activeNav={config.path}
>
  <PageHero eyebrow={config.label} title={config.label} lead={config.description} compact />
  <div class="reveal">
    <PostList posts={posts} />
  </div>
</BaseLayout>
