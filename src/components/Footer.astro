---
import { SITE } from '@/lib/constants';
---

<footer class="bg-apple-gray-900 text-white mt-24">
  <div class="max-w-page mx-auto px-6 py-20">
    <div class="grid md:grid-cols-3 gap-16">
      <div>
        <h3 class="text-[11px] font-semibold uppercase tracking-[0.12em] text-apple-gray-400 mb-4">Subscribe</h3>
        <p class="text-apple-gray-300 text-sm leading-relaxed mb-5">
          Get new posts delivered to your inbox.
        </p>
        <form class="flex gap-2" action="#" method="POST">
          <input 
            type="email" 
            name="email" 
            placeholder="your@email.com" 
            required 
            class="flex-1 min-w-0 px-3.5 py-2.5 bg-apple-gray-800 border border-apple-gray-700 rounded-xl text-sm text-white placeholder-apple-gray-500 focus:outline-none focus:ring-2 focus:ring-apple-orange/40 focus:border-apple-orange transition-all"
          />
          <button 
            type="submit" 
            class="px-4 py-2.5 bg-apple-orange text-white rounded-xl text-sm font-medium hover:brightness-110 transition-all active:scale-[0.98]"
          >
            Subscribe
          </button>
        </form>
        <div class="flex gap-4 mt-4">
          <a href="/rss.xml" class="text-[13px] text-apple-gray-400 hover:text-white transition-colors">RSS Feed</a>
          <span class="text-apple-gray-600">·</span>
          <a href="/atom.xml" class="text-[13px] text-apple-gray-400 hover:text-white transition-colors">Atom Feed</a>
        </div>
      </div>

      <div>
        <h3 class="text-[11px] font-semibold uppercase tracking-[0.12em] text-apple-gray-400 mb-4">Connect</h3>
        <ul class="space-y-1.5 list-none p-0 m-0">
          <li><a href={SITE.social.twitter} target="_blank" rel="noopener" class="flex items-center gap-2.5 text-[15px] text-apple-gray-300 hover:text-white transition-colors"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16z"/><path d="M4 20l6.768 -6.768m2.46 -2.46L20 4"/></svg>Twitter / X</a></li>
          <li><a href={SITE.social.github} target="_blank" rel="noopener" class="flex items-center gap-2.5 text-[15px] text-apple-gray-300 hover:text-white transition-colors"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>GitHub</a></li>
          <li><a href={SITE.social.linkedin} target="_blank" rel="noopener" class="flex items-center gap-2.5 text-[15px] text-apple-gray-300 hover:text-white transition-colors"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>LinkedIn</a></li>
          <li><a href={SITE.social.instagram} target="_blank" rel="noopener" class="flex items-center gap-2.5 text-[15px] text-apple-gray-300 hover:text-white transition-colors"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>Instagram</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-[11px] font-semibold uppercase tracking-[0.12em] text-apple-gray-400 mb-4">Colophon</h3>
        <p class="text-apple-gray-400 text-sm leading-relaxed mb-1">
          Built with <a href="https://astro.build" class="text-apple-gray-300 hover:text-white transition-colors">Astro</a>.
        </p>
        <p class="text-apple-gray-400 text-sm leading-relaxed mb-6">
          Deployed on <a href="https://vercel.com" class="text-apple-gray-300 hover:text-white transition-colors">Vercel</a>.
        </p>
        <p class="text-apple-gray-500 text-xs">
          &copy; {new Date().getFullYear()} {SITE.author}. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
