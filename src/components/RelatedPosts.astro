---
import PostList from '@/components/PostList.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
  title?: string;
}

const { posts, title = 'Continue reading' } = Astro.props;
---

{
  posts.length > 0 && (
    <section class="related-posts reveal" aria-labelledby="related-heading">
      <h2 id="related-heading" class="section-title section-title--small">
        {title}
      </h2>
      <PostList posts={posts} showArrow={true} />
    </section>
  )
}
