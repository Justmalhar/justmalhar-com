---
import { getCollection } from 'astro:content';
import { SITE } from '@/lib/constants';
import { getPopularTags } from '@/lib/utils';

const blog = await getCollection('blog');
const links = await getCollection('links');
const quotes = await getCollection('quotes');

const allPosts = [...blog, ...links, ...quotes];
const popularTags = getPopularTags(allPosts, 5);
---

<div class="border-t border-apple-gray-100 px-5 sm:px-8 lg:px-10 py-10">
  <div class="rounded-xl border border-apple-gray-100 p-5 mb-8">
    <h3 class="text-[15px] font-semibold text-apple-gray-900 mb-1">
      Get new posts in your inbox
    </h3>
    <form class="mt-4 flex gap-2" action="#" method="POST">
      <input
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        class="flex-1 min-w-0 px-3.5 py-2.5 bg-apple-gray-50 border border-apple-gray-100 rounded-lg text-[14px] placeholder-apple-gray-400 focus:outline-none focus:ring-2 focus:ring-apple-orange/30 focus:border-apple-orange transition-all"
      />
      <button
        type="submit"
        class="px-4 py-2.5 bg-apple-orange text-white rounded-lg text-[14px] font-medium hover:brightness-110 transition-all shrink-0"
      >
        Subscribe
      </button>
    </form>
  </div>

  {popularTags.length > 0 && (
    <div class="mb-8">
      <h3 class="text-[11px] font-semibold uppercase tracking-[0.08em] text-apple-gray-400 mb-3">
        Popular Tags
      </h3>
      <div class="flex flex-wrap gap-2">
        {popularTags.map(({ tag }) => (
          <a
            href={`/tags/${tag}`}
            class="px-3 py-1.5 text-[13px] text-apple-gray-600 bg-apple-gray-50 rounded-lg hover:bg-apple-gray-100 transition-colors capitalize"
          >
            #{tag}
          </a>
        ))}
      </div>
    </div>
  )}

  <p class="text-[12px] text-apple-gray-400">
    &copy; {new Date().getFullYear()} {SITE.author}. Built with <a href="https://astro.build" class="text-apple-gray-500 hover:text-apple-orange transition-colors">Astro</a>.
  </p>
</div>
