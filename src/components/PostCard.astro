---
import type { CollectionEntry } from 'astro:content';
import { formatDate, getPostUrl } from '@/lib/utils';

type Post = CollectionEntry<'essays'> | CollectionEntry<'links'> | CollectionEntry<'notes'> | CollectionEntry<'quotes'> | CollectionEntry<'guides'>;

interface Props {
  post: Post;
}

const { post } = Astro.props;
const url = getPostUrl(post);
const collectionLabel = post.collection.charAt(0).toUpperCase() + post.collection.slice(1);
const postData = post.data as Record<string, unknown>;
const hasTitle = typeof postData.title === 'string';
const hasDescription = typeof postData.description === 'string';
const hasVia = typeof postData.via === 'string';
const hasAuthor = typeof postData.author === 'string';

// Type-based accent colors
const typeColors: Record<string, string> = {
  essays: 'border-l-accent-blue',
  links: 'border-l-accent-green',
  notes: 'border-l-gray-400',
  quotes: 'border-l-accent-amber',
  guides: 'border-l-accent-purple',
};

const typeTextColors: Record<string, string> = {
  essays: 'text-accent-blue',
  links: 'text-accent-green',
  notes: 'text-gray-500',
  quotes: 'text-accent-amber',
  guides: 'text-accent-purple',
};

const borderColor = typeColors[post.collection] || 'border-l-gray-300';
const textColor = typeTextColors[post.collection] || 'text-gray-500';
---

<article class={`pl-4 border-l-4 ${borderColor} py-4`}>
  <div class="flex items-center gap-3 mb-2">
    <span class={`text-xs font-mono uppercase tracking-wider ${textColor}`}>{collectionLabel}</span>
    <span class="text-gray-300">·</span>
    <time datetime={post.data.pubDate.toISOString()} class="text-sm text-gray-500">
      {formatDate(post.data.pubDate)}
    </time>
  </div>
  
  {hasTitle ? (
    <h3 class="text-lg font-bold text-gray-900 mb-1">
      <a href={url} class="hover:text-accent-blue transition-colors">
        {postData.title as string}
      </a>
    </h3>
  ) : null}
  
  {post.collection === 'quotes' ? (
    <blockquote class="text-gray-600 italic">
      <p>"{post.body?.slice(0, 200)}..."</p>
      <cite class="text-sm text-gray-500 not-italic">— {hasAuthor ? postData.author : ''}</cite>
    </blockquote>
  ) : post.collection === 'links' ? (
    <div class="text-gray-600">
      <a href={postData.externalUrl as string} target="_blank" rel="noopener" class="text-accent-green hover:underline">
        {hasTitle ? postData.title : postData.externalUrl} ↗
      </a>
      {hasVia && (
        <span class="text-sm text-gray-400 ml-2">via {postData.via}</span>
      )}
    </div>
  ) : hasDescription ? (
    <p class="text-gray-600">{postData.description as string}</p>
  ) : null}
  
  {post.data.tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mt-3">
      {post.data.tags.map(tag => (
        <a href={`/tags/${tag}`} class="text-xs font-mono text-gray-400 hover:text-gray-600 transition-colors">
          #{tag}
        </a>
      ))}
    </div>
  )}
</article>
